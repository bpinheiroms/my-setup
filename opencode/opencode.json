{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/kimi-k2.6",
  "default_agent": "sisyphus",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 16000
  },
  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      ".turbo/**",
      "dist/**",
      "build/**"
    ]
  },
  "command": {
    "go": {
      "description": "Run through Oh My OpenAgent Sisyphus on OpenCode Go",
      "agent": "sisyphus",
      "model": "opencode-go/kimi-k2.6",
      "template": "$ARGUMENTS"
    }
  },
  "plugin": [
    "oh-my-openagent@latest"
  ]
}
